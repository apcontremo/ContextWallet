<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Imagen de fondo -->
    <ImageView
        android:id="@+id/backgroundImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/cw_bg"
        android:alpha="1.0" /> <!-- Restore original appearance -->

    <!-- Efecto de cristal -->
    <View
        android:id="@+id/glassEffect"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3000000" /> <!-- Negro con ~70% de opacidad -->

    <!-- Contenedor para el contenido principal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp">

        <!-- Ejemplo de texto -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bienvenido a ContextWallet"
            android:textSize="24sp"
            android:textColor="@android:color/white"
            android:gravity="center" />

        <!-- Botón de ejemplo -->
        <Button
            android:id="@+id/exampleButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Comenzar"
            android:layout_marginTop="16dp" />

    </LinearLayout>

</RelativeLayout>